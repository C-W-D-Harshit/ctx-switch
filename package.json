{
  "name": "ctx-switch",
  "version": "2.0.7",
  "description": "Switch coding agents without losing context. Generate handoff prompts across Claude Code, Codex, and OpenCode.",
  "type": "module",
  "main": "./dist/index.mjs",
  "exports": "./dist/index.mjs",
  "bin": {
    "ctx-switch": "./dist/index.mjs",
    "cc-continue": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && node --import tsx --test test/**/*.test.ts",
    "smoke:help": "npm run build --silent && node dist/index.mjs --help",
    "smoke:doctor": "npm run build --silent && node dist/index.mjs doctor",
    "prepack": "npm run build"
  },
  "keywords": [
    "ctx-switch",
    "claude-code",
    "claude",
    "codex",
    "opencode",
    "ai",
    "cli",
    "continuation",
    "handoff",
    "context-switch",
    "openrouter",
    "agent"
  ],
  "author": "Harshit",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "bugs": {
    "url": "https://github.com/C-W-D-Harshit/ctx-switch/issues"
  },
  "homepage": "https://github.com/C-W-D-Harshit/ctx-switch#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/C-W-D-Harshit/ctx-switch"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "esbuild": "^0.25.9",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
